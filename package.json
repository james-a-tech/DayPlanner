{
  "name": "dayplanner",
  "version": "1.0.0",
  "description": "Day Planner - Task Management & Scheduling Web App",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:python\" \"npm run frontend\"",
    "dev:python": "cd backend && python -m uvicorn app.main:app --reload --host 0.0.0.0 --port 5000",
    "dev:node": "concurrently \"npm run dev --prefix backend\" \"npm run dev --prefix frontend\"",
    "start:python": "cd backend && python -m uvicorn app.main:app --host 0.0.0.0 --port 5000",
    "build": "npm run build --prefix backend && npm run build --prefix frontend",
    "backend": "npm run dev --prefix backend",
    "frontend": "npm run dev --prefix frontend"
  },
  "keywords": [
    "planner",
    "tasks",
    "scheduling",
    "time management",
    "productivity"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
